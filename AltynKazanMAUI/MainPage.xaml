<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:AltynKazanMAUI.Models"
             x:Class="AltynKazanMAUI.MainPage"
             BackgroundColor="#F9FAFB">

    <ContentPage.Resources>
        <Color x:Key="AccentGold">#B38F4D</Color>
        <Color x:Key="GoldBgLight">#FAF6EE</Color>
        <Color x:Key="TextDark">#1A1A1A</Color>
        <Color x:Key="TextGray">#6B7280</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <!-- ОБЩИЙ ФОНОВЫЙ УЗОР НА ВСЮ СТРАНИЦУ -->
        <!-- Лежит под всем контентом (Grid.RowSpan="2"), едва заметный, замощён по всей площади -->
        <Image Grid.Row="0" Grid.RowSpan="2"
               Source="nat_pattern.png"
               Aspect="AspectFill"
               Opacity="0.045"
               InputTransparent="True"
               ZIndex="-1"/>

        <VerticalStackLayout Grid.Row="0" Padding="0, 10, 0, 0" BackgroundColor="Transparent">
            <Grid HorizontalOptions="Center" ColumnDefinitions="Auto, Auto, Auto">

                <Image Grid.Column="0" 
                       Source="nat_pattern.png" 
                       WidthRequest="70" 
                       HeightRequest="70" 
                       Opacity="0.25" 
                       VerticalOptions="Center" 
                       Margin="0,0,25,0"/>

                <Image Grid.Column="1" 
                       Source="altynlogo.png" 
                       WidthRequest="400" 
                       HeightRequest="100" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <Image Grid.Column="2" 
                       Source="nat_pattern.png" 
                       WidthRequest="70" 
                       HeightRequest="70" 
                       Opacity="0.25" 
                       VerticalOptions="Center" 
                       Margin="25,0,0,0"/>
            </Grid>

            <Grid Margin="0,15,0,0">
                <!-- Тонкая полоска-узор вместо однотонной линии -->
                <BoxView HeightRequest="1" Color="#E5E7EB" HorizontalOptions="Fill"/>
                <Image Source="nat_pattern.png"
                       Aspect="AspectFit"
                       HeightRequest="20"
                       Opacity="0.15"
                       HorizontalOptions="Center"
                       InputTransparent="True"/>
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="180, *" Padding="10, 5, 15, 10">

            <Grid Grid.Column="0">
                <Image Source="nat_pattern.png" 
                       Aspect="AspectFit" 
                       HorizontalOptions="Start" 
                       VerticalOptions="Start"
                       WidthRequest="100" 
                       HeightRequest="100"
                       Opacity="0.10" 
                       Margin="10,10,0,0"
                       InputTransparent="True"/>

                <Image Source="nat_pattern.png" 
                       Aspect="AspectFit" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"
                       WidthRequest="140" 
                       HeightRequest="140"
                       Opacity="0.07" 
                       InputTransparent="True"/>

                <Image Source="nat_pattern.png" 
                       Aspect="AspectFit" 
                       HorizontalOptions="Center" 
                       VerticalOptions="End"
                       WidthRequest="170" 
                       HeightRequest="170"
                       Opacity="0.18" 
                       Margin="0,0,0,10"
                       InputTransparent="True"/>

                <CollectionView x:Name="CategoriesCollectionView" 
                                SelectionMode="Single"
                                Margin="5,0,0,0"
                                SelectionChanged="OnCategoryChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="CatGrid" Margin="0,3" ColumnDefinitions="4, *">
                                <BoxView x:Name="ActiveIndicator" 
                                         Grid.Column="0" 
                                         WidthRequest="4" 
                                         CornerRadius="2"
                                         Color="Transparent" />

                                <Border x:Name="CatBorder" 
                                        Grid.Column="1"
                                        StrokeShape="RoundRectangle 0,8,8,0" 
                                        StrokeThickness="0" 
                                        BackgroundColor="Transparent">

                                    <Grid>
                                        <Image x:Name="SelectedCatPattern"
                                               Source="nat_pattern.png"
                                               HorizontalOptions="End"
                                               VerticalOptions="Center"
                                               WidthRequest="35"
                                               HeightRequest="35"
                                               Opacity="0"
                                               Margin="0,0,5,0"/>

                                        <Label x:Name="CatLabel" 
                                               Text="{Binding .}" 
                                               FontSize="14" 
                                               TextColor="{StaticResource TextGray}"
                                               Padding="12,10" 
                                               VerticalOptions="Center"
                                               HorizontalOptions="Start"/>
                                    </Grid>
                                </Border>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup Name="CommonStates">
                                        <VisualState Name="Normal" />
                                        <VisualState Name="Selected">
                                            <VisualState.Setters>
                                                <Setter TargetName="ActiveIndicator" Property="BoxView.Color" Value="{StaticResource AccentGold}"/>
                                                <Setter TargetName="CatBorder" Property="Border.BackgroundColor" Value="{StaticResource GoldBgLight}"/>
                                                <Setter TargetName="CatLabel" Property="Label.TextColor" Value="{StaticResource AccentGold}"/>
                                                <Setter TargetName="CatLabel" Property="Label.FontAttributes" Value="Bold"/>
                                                <Setter TargetName="SelectedCatPattern" Property="Image.Opacity" Value="0.15"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Grid Grid.Column="1" Margin="10,0,0,0">

                <Image Source="nat_pattern.png" 
                       Aspect="AspectFit" 
                       VerticalOptions="Center"
                       WidthRequest="450" 
                       HeightRequest="450"
                       Opacity="0.05" 
                       Margin="0,0,-50,0"
                       InputTransparent="True"/>

                <Image Source="nat_pattern.png" 
                       Aspect="AspectFit" 
                       HorizontalOptions="Start"
                       VerticalOptions="Start"
                       WidthRequest="90" 
                       HeightRequest="90"
                       Opacity="0.06" 
                       Margin="20,20,0,0"
                       InputTransparent="True"/>

                <ScrollView x:Name="MenuScrollView" 
                            VerticalScrollBarVisibility="Never"
                            Scrolled="OnMenuScrolled">

                    <VerticalStackLayout x:Name="MenuGroupsContainer" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:DishGroup">
                                <VerticalStackLayout Spacing="0">

                                    <Grid HorizontalOptions="Center" ColumnDefinitions="Auto, Auto, Auto" Margin="0, 15, 0, 15">
                                        <Image Grid.Column="0" 
                                               Source="nat_pattern.png" 
                                               WidthRequest="35" 
                                               HeightRequest="35" 
                                               Opacity="0.20" 
                                               VerticalOptions="Center" 
                                               Margin="0,0,15,0"/>

                                        <Label Grid.Column="1" 
                                               Text="{Binding CategoryName}"
                                               FontSize="23"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextDark}"
                                               VerticalOptions="Center" />

                                        <Image Grid.Column="2" 
                                               Source="nat_pattern.png" 
                                               WidthRequest="35" 
                                               HeightRequest="35" 
                                               Opacity="0.20" 
                                               VerticalOptions="Center" 
                                               Margin="15,0,0,0"/>
                                    </Grid>

                                    <FlexLayout BindableLayout.ItemsSource="{Binding .}"
                                                 Direction="Row"
                                                 Wrap="Wrap"
                                                 JustifyContent="Start"
                                                 AlignItems="Start"
                                                 AlignContent="Start">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:Dish">

                                                <Grid FlexLayout.Basis="50%" Padding="12" HeightRequest="340">
                                                    <Border StrokeShape="RoundRectangle 20" 
                                                            Stroke="#E5E7EB" 
                                                            StrokeThickness="1" 
                                                            BackgroundColor="White">

                                                        <Grid RowDefinitions="220, Auto, *" Padding="0,0,0,0">

                                                            <Grid Grid.Row="0" BackgroundColor="#FAF6EE">
                                                                <Image Source="nat_pattern.png" 
                                                                       Aspect="AspectFit" 
                                                                       Opacity="0.15" 
                                                                       WidthRequest="120" 
                                                                       HeightRequest="120"
                                                                       HorizontalOptions="Center" 
                                                                       VerticalOptions="Center"/>

                                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                                                <Border StrokeShape="RoundRectangle 12" 
                                                                        Stroke="#E5E7EB"
                                                                        StrokeThickness="1" 
                                                                        BackgroundColor="White"
                                                                        HorizontalOptions="End"
                                                                        VerticalOptions="Start"
                                                                        Margin="15"
                                                                        Padding="14,8">
                                                                    <Label Text="{Binding Price, StringFormat='{0} сом'}" 
                                                                           FontSize="14" 
                                                                           FontAttributes="Bold" 
                                                                           TextColor="{StaticResource AccentGold}"
                                                                           VerticalOptions="Center"
                                                                           HorizontalOptions="Center"/>
                                                                </Border>
                                                            </Grid>

                                                            <Label Grid.Row="1" 
                                                                   Text="{Binding Name}" 
                                                                   FontSize="19" 
                                                                   FontAttributes="Bold" 
                                                                   TextColor="{StaticResource TextDark}" 
                                                                   Margin="20,18,20,0"/>

                                                            <Label Grid.Row="2" 
                                                                   Text="{Binding Description}"
                                                                   TextColor="{StaticResource TextGray}" 
                                                                   MaxLines="2"
                                                                   LineHeight="1.2"
                                                                   Margin="20,6,20,0"
                                                                   VerticalOptions="Start"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>

                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>
