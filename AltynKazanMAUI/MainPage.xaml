<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AltynKazanMAUI.MainPage"
             BackgroundColor="#F9FAFB">

    <ContentPage.Resources>
        <Color x:Key="AccentGold">#B38F4D</Color>
        <Color x:Key="GoldBgLight">#FAF6EE</Color>
        <Color x:Key="TextDark">#1A1A1A</Color>
        <Color x:Key="TextGray">#6B7280</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="0, 40, 0, 20" BackgroundColor="Transparent">
            <Label Text="ALTYN KAZAN" 
                   TextColor="{StaticResource TextDark}" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   CharacterSpacing="6"/>
            <Label Text="Изысканный вкус традиций" 
                   TextColor="{StaticResource TextGray}" 
                   FontSize="13" 
                   HorizontalOptions="Center" 
                   Margin="0,4,0,0"
                   CharacterSpacing="1"/>
            <BoxView HeightRequest="1" 
                     Color="#E5E7EB" 
                     Margin="0,25,0,0" 
                     HorizontalOptions="Fill"/>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="260, *" Padding="20, 10, 20, 20">

            <CollectionView x:Name="CategoriesCollectionView" 
                            Grid.Column="0" 
                            SelectionMode="Single"
                            SelectionChanged="OnCategoryChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="CatGrid" Margin="0,4" ColumnDefinitions="4, *">
                            <BoxView x:Name="ActiveIndicator" 
                                     Grid.Column="0" 
                                     WidthRequest="4" 
                                     CornerRadius="2"
                                     Color="Transparent" />

                            <Border x:Name="CatBorder" 
                                    Grid.Column="1"
                                    StrokeShape="RoundRectangle 0,8,8,0" 
                                    StrokeThickness="0" 
                                    BackgroundColor="Transparent">
                                <Label x:Name="CatLabel" 
                                       Text="{Binding .}" 
                                       FontSize="16" 
                                       TextColor="{StaticResource TextGray}"
                                       Padding="20,14" 
                                       VerticalOptions="Center"
                                       HorizontalOptions="Start"/>
                            </Border>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal" />
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter TargetName="ActiveIndicator" Property="BoxView.Color" Value="{StaticResource AccentGold}"/>
                                            <Setter TargetName="CatBorder" Property="Border.BackgroundColor" Value="{StaticResource GoldBgLight}"/>
                                            <Setter TargetName="CatLabel" Property="Label.TextColor" Value="{StaticResource AccentGold}"/>
                                            <Setter TargetName="CatLabel" Property="Label.FontAttributes" Value="Bold"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView x:Name="MenuCollectionView" 
                            Grid.Column="1" 
                            Margin="25,0,0,0"
                            IsGrouped="True">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate>
                        <Label Text="{Binding CategoryName}"
                               FontSize="23"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextDark}"
                               HorizontalOptions="Start"
                               Margin="0, 10, 0, 15" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="24" VerticalItemSpacing="24"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="White">
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,6" Radius="14" Opacity="0.04"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="220, Auto, *" Padding="0,0,0,20">
                                <Grid Grid.Row="0">
                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                    <Border StrokeShape="RoundRectangle 12" 
                                            StrokeThickness="0" 
                                            BackgroundColor="White"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="15"
                                            Padding="14,8">
                                        <Border.Shadow>
                                            <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.18"/>
                                        </Border.Shadow>
                                        <Label Text="{Binding Price, StringFormat='{0} сом'}" 
                                               FontSize="14" 
                                               FontAttributes="Bold" 
                                               TextColor="{StaticResource AccentGold}"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"/>
                                    </Border>
                                </Grid>

                                <Label Grid.Row="1" 
                                       Text="{Binding Name}" 
                                       FontSize="19" 
                                       FontAttributes="Bold" 
                                       TextColor="{StaticResource TextDark}" 
                                       Margin="20,18,20,0"/>

                                <Label Grid.Row="2" 
                                       Text="{Binding Description}"
                                       TextColor="{StaticResource TextGray}" 
                                       MaxLines="2"
                                       LineHeight="1.2"
                                       Margin="20,6,20,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>